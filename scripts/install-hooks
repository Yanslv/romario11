#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    if command -v powershell.exe >/dev/null 2>&1; then
      powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_DIR/install-hooks.ps1"
    else
      sh "$SCRIPT_DIR/install-hooks.sh"
    fi
    ;;
  *)
    sh "$SCRIPT_DIR/install-hooks.sh"
    ;;
esac
